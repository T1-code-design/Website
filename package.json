{
  "name": "tech-company-website",
  "version": "0.1.0",
  "private": true,
  "description": "A modern tech company landing page built with HTML, Tailwind CSS, and JavaScript.",
  "scripts": {
    "build:css": "npx tailwindcss -i ./src/styles.css -o ./src/styles.css --minify",
    "watch:css": "npx tailwindcss -i ./src/styles.css -o ./src/styles.css --watch",
    "build": "npm run build:css"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.5"
  }
}
